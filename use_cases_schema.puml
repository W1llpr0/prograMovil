@startuml
left to right direction
skinparam packageStyle rectangle

' Definición de Actores
actor "Usuario" as user
actor "Cliente" as client
actor "Veterinario" as vet

' Herencia de Actores (Cliente y Veterinario son Usuarios)
client -up-|> user
vet -up-|> user

' Sistema / Aplicación
rectangle "Aplicación Móvil Veterinaria" {
  
  ' Casos de Uso Comunes (RF01, RF02, RF03)
  usecase "CU01: Registrarse en la app" as UC1
  usecase "CU08: Iniciar Sesión" as UC8
  usecase "CU09: Editar Perfil" as UC9
  
  ' Casos de Uso del Cliente
  usecase "CU02: Gestionar Mascotas" as UC2
  usecase "CU03: Agendar Consulta Médica" as UC3
  usecase "CU04: Evaluar Atención" as UC4
  usecase "CU10: Visualizar Historial Clínico" as UC10
  
  ' Casos de Uso del Veterinario
  usecase "CU05: Gestionar Agenda Médica" as UC5
  usecase "CU06: Registrar Historial Clínico" as UC6
  usecase "CU07: Adjuntar Resultados Médicos" as UC7
}

' Relaciones entre Actores y Casos de Uso
user --> UC1
user --> UC8
user --> UC9

client --> UC2
client --> UC3
client --> UC4
client --> UC10

vet --> UC5
vet --> UC6
vet --> UC7

' Notas
note right of UC10 : Cubre RF13\n(Ver recetas y documentos)
note bottom of UC6 : El Veterinario registra,\n el Cliente (UC10) visualiza.

@enduml